# All variables below are SERVER-SIDE ONLY.
# Set them in Vercel: Project Settings -> Environment Variables.
# Never commit a real .env file (already ignored via .gitignore).

# Password protecting GET /api/night-watchers
NIGHT_WATCHERS_PASS=replace-with-a-strong-secret

# Supabase (free tier) credentials. Create the table with:
#
#   create table visits (
#     id bigint generated always as identity primary key,
#     ip text,
#     ua text,
#     browser text,
#     os text,
#     referrer text,
#     page text,
#     created_at timestamptz default now()
#   );
#   alter table visits enable row level security;
#   -- No public policies: data is only reachable with the service key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Allowed origin for the tracking endpoint
SITE_ORIGIN=https://saurav-ggd-portfolio.vercel.app
